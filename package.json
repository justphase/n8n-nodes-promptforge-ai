{
  "name": "n8n-nodes-promptforge-ai",
  "version": "0.1.4",
  "description": "Generate optimized prompts for ChatGPT, Claude, Gemini, Grok and other LLMs.",
  "keywords": [
    "n8n-community-node-package",
    "n8n",
    "prompt",
    "ai",
    "chatgpt",
    "claude",
    "gemini",
    "grok",
    "llm"
  ],
  "license": "MIT",
  "homepage": "https://github.com/justphase/n8n-nodes-promptforge-ai",
  "author": {
    "name": "Aaditya Mishra",
    "email": "aadityamishra4000@gmail.com"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/justphase/n8n-nodes-promptforge-ai.git"
  },
  "main": "index.js",
  "scripts": {
    "build": "npx rimraf dist && tsc -p tsconfig.json && gulp build:icons",
    "dev": "tsc -p tsconfig.json --watch",
    "format": "prettier nodes --write",
    "lint": "eslint nodes package.json",
    "lintfix": "eslint nodes package.json --fix",
    "prepublishOnly": "npm run build && npm run lint -c .eslintrc.prepublish.js nodes package.json"
  },
  "files": [
    "dist"
  ],
  "n8n": {
    "n8nNodesApiVersion": 1,
    "credentials": [],
    "nodes": [
      "dist/nodes/PromptForgeAi/PromptForgeAi.node.js"
    ]
  },
  "devDependencies": {
    "@typescript-eslint/parser": "~8.32.0",
    "eslint": "^8.57.0",
    "eslint-plugin-n8n-nodes-base": "^1.16.3",
    "gulp": "^4.0.2",
    "n8n-workflow": "*",
    "prettier": "^3.5.3",
    "rimraf": "^6.0.1",
    "typescript": "^5.8.2"
  },
  "peerDependencies": {
    "n8n-workflow": "*"
  }
}
